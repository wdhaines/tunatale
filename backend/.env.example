# Copy to backend/.env (cp .env.example .env) and fill in what you need.
# Placeholders only — never commit real keys. Full settings surface (and the
# authoritative comments): app/config.py. Unknown keys are ignored.

# --- LLM (Groq) ---
GROQ_API_KEY=your-key-here
LLM_MODE=mock   # mock (CI-safe cassette replay) | live | record | patch

# --- Databases (per-language isolation) ---
# Single-language: DATABASE_URL + TARGET_LANGUAGE together (default: Slovene).
DATABASE_URL=sqlite:///./tunatale_sl.db
TARGET_LANGUAGE=sl
# Simultaneous multi-language: one DB per language (JSON dict; overrides
# DATABASE_URL; active language resolved per request from the X-TT-Language
# header). Safe alongside e2e — playwright.config.ts overrides DATABASE_URLS
# per-webServer, so test runs can't leak into these DBs.
# DATABASE_URLS={"sl": "sqlite:///./tunatale_sl.db", "no": "sqlite:///./tunatale_no.db"}

# --- Lemmatization ---
# "lowercase" (default) = deterministic engine for every language (the CI/test
# pin). Any other value ("auto", "classla", "stanza") opts in to the
# per-language registry engines (sl→classla, no→stanza; PyTorch model downloads).
# LEMMATIZER_TYPE=auto

# --- Anki sync (optional; SYNC_ENABLED defaults true) ---
# ANKI_COLLECTION_PATH=/Users/<you>/Library/Application Support/Anki2/<profile>/collection.anki2
# ANKI_MEDIA_PATH=/Users/<you>/Library/Application Support/Anki2/<profile>/collection.media
# ANKI_DECK_NAME=1. Slovene
# SYNC_USERNAME=you@example.com
# AnkiWeb password: prefer the macOS Keychain over this plaintext fallback —
#   security add-generic-password -s tunatale-ankiweb -a <username> -w
# SYNC_PASSWORD=
# SYNC_ENDPOINT=   # empty = AnkiWeb; else self-hosted sync server URL

# --- Media enrichment (optional) ---
# A real key in dev fetches card images at add time; tests must pin this EMPTY.
# PIXABAY_API_KEY=
